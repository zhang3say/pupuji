# 噗噗记 — 环境变量
# 复制此文件为 .env 后按需修改

# PostgreSQL 数据库连接
DATABASE_URL=postgresql+asyncpg://pupuji:pupuji_dev@localhost:5432/pupuji

# JWT 密钥（生产环境务必更换！）
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# 短信验证码
SMS_CODE_LENGTH=6
SMS_CODE_TTL=300
SMS_RESEND_SECONDS=60
