# 噗噗记 — 环境变量
# 复制此文件为 .env 后按需修改

# PostgreSQL 数据库连接
# 如果使用已有的 local-postgres 容器，用实际的用户名密码：
DATABASE_URL=postgresql+asyncpg://testuser:testpass@localhost:5432/pupuji

# 如果使用 docker compose 启动全新实例：
# DATABASE_URL=postgresql+asyncpg://pupuji:pupuji_dev@localhost:5432/pupuji

# Redis 连接
REDIS_URL=redis://localhost:6379/0

# JWT 密钥（生产环境务必更换！）
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# 短信验证码
SMS_CODE_LENGTH=6
SMS_CODE_TTL=300
SMS_RESEND_SECONDS=60
